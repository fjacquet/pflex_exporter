# Copy to .env and fill in — `.env` is gitignored, never commit real secrets.
# Compose reads .env natively, and the pflex_exporter binary itself loads .env from
# the working directory (or next to config.yaml). Already-set environment variables
# always take precedence over .env values.

# Gateway hostname or IP for the first PowerFlex cluster (PowerFlex Manager UI ingress).
# config.yaml references it as ${PFLEX1_GATEWAY}.
PFLEX1_GATEWAY=flex-clu1-gw01

# Username for the PowerFlex monitoring user. A 'monitor'-type user is sufficient.
# config.yaml references it as ${PFLEX1_USERNAME}.
PFLEX1_USERNAME=flex-username

# Password for the PowerFlex monitoring user. config.yaml references it as ${PFLEX1_PASSWORD}.
# Special characters: wrap the value in single quotes so it is taken literally, e.g.
# PFLEX1_PASSWORD='p@$$w0rd!#{}'. Double quotes expand $VAR and process backslashes;
# unquoted values treat " #" (space-hash) as a comment. For a literal ' use double
# quotes ("p'ass"); for a " use single quotes ('p"ass'); for both, a backslash, or a
# value starting with a quote, use passwordFile in config.yaml instead (read verbatim).
PFLEX1_PASSWORD=changeme
