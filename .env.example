# Copy to .env and fill in — `.env` is gitignored, never commit real secrets.
# Used by docker-compose.yml and docker-compose.ghcr.yml (single-cluster quickstart).

# Gateway hostname or IP for the first PowerFlex cluster (PowerFlex Manager UI ingress).
# config.yaml references it as ${FLEX1_GATEWAY}.
FLEX1_GATEWAY=flex-clu1-gw01

# Username for the PowerFlex monitoring user. A 'monitor'-type user is sufficient.
# config.yaml references it as ${FLEX1_USERNAME}.
FLEX1_USERNAME=flex-username

# Password for the PowerFlex monitoring user. config.yaml references it as ${FLEX1_PASSWORD}.
FLEX1_PASSWORD=changeme
