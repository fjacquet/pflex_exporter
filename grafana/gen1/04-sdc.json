{
  "title": "PowerFlex Gen1 - SDC",
  "uid": "pflex-g1-sdc",
  "tags": ["powerflex", "gen1", "pflex_exporter"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0 },
      { "name": "cluster", "type": "query", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "query": "label_values(pflex_up, cluster)", "refresh": 2, "includeAll": true, "multi": true, "current": { "text": "All", "value": "$__all" } }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "SDC IOPS", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "iops" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (sdc_name, direction) (pflex_sdc_iops{cluster=~\"$cluster\", op=\"userData\"})", "legendFormat": "{{sdc_name}} {{direction}}" } ]
    },
    {
      "id": 2, "title": "SDC Bandwidth (KB/s)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "KBs" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (sdc_name, direction) (pflex_sdc_bandwidth_kb_per_second{cluster=~\"$cluster\", op=\"userData\"})", "legendFormat": "{{sdc_name}} {{direction}}" } ]
    },
    {
      "id": 3, "title": "Mapped Volumes per SDC", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "max by (sdc_name) (pflex_sdc_num_of_mapped_volumes{cluster=~\"$cluster\"})", "legendFormat": "{{sdc_name}}" } ]
    }
  ]
}
