{
  "title": "PowerFlex Gen1 - Protection Domains",
  "uid": "pflex-g1-pd",
  "tags": [
    "powerflex",
    "pflex_exporter"
  ],
  "schemaVersion": 39,
  "version": 2,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(pflex_up, cluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Performance",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "IOPS",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (protection_domain_name) (pflex_protectiondomain_iops{cluster=~\"$cluster\", op=\"total\"})",
          "legendFormat": "{{protection_domain_name}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Bandwidth",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "KBs",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (protection_domain_name) (pflex_protectiondomain_bandwidth_kb_per_second{cluster=~\"$cluster\", op=\"total\"})",
          "legendFormat": "{{protection_domain_name}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (protection_domain_name) (pflex_protectiondomain_latency{cluster=~\"$cluster\", op=\"target\"})",
          "legendFormat": "{{protection_domain_name}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Capacity & Resilience",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Capacity At Risk (KiB)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "deckbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (protection_domain_name) (pflex_protectiondomain_degraded_failed_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "degraded+failed"
        },
        {
          "refId": "B",
          "expr": "sum by (protection_domain_name) (pflex_protectiondomain_failed_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Rebuild / Rebalance Remaining (KiB)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "deckbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (protection_domain_name) (pflex_protectiondomain_bck_rebuild_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "bck rebuild"
        },
        {
          "refId": "B",
          "expr": "sum by (protection_domain_name) (pflex_protectiondomain_rebalance_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "rebalance"
        }
      ]
    }
  ],
  "description": "Protection domain resilience, rebuild, and back-end latency."
}
