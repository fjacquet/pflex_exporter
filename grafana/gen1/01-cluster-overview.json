{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "title": "PowerFlex - Cluster Overview",
  "uid": "pflex-cluster-overview",
  "tags": [
    "powerflex",
    "pflex_exporter"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "version": 2,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(pflex_up, cluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Health & Status",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Clusters Up",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pflex_up{cluster=~\"$cluster\"})",
          "legendFormat": "Clusters Up"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Capacity Used %",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 4,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (cluster) (pflex_cluster_capacity_in_use_in_kb{cluster=~\"$cluster\"}) / clamp_min(sum by (cluster) (pflex_cluster_max_capacity_in_kb{cluster=~\"$cluster\"}), 1)",
          "legendFormat": "Capacity Used %"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Capacity At Risk %",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 9,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (cluster) (pflex_cluster_degraded_failed_capacity_in_kb{cluster=~\"$cluster\"}) / clamp_min(sum by (cluster) (pflex_cluster_max_capacity_in_kb{cluster=~\"$cluster\"}), 1)",
          "legendFormat": "Capacity At Risk %"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Worst Component Health",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 14,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Healthy",
                  "color": "green"
                },
                "1": {
                  "text": "Degraded",
                  "color": "yellow"
                },
                "2": {
                  "text": "Failed",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(pflex_sds_health{cluster=~\"$cluster\"} or pflex_device_health{cluster=~\"$cluster\"} or pflex_sdc_health{cluster=~\"$cluster\"})",
          "legendFormat": "Worst Component Health"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Compression Ratio",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 19,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (cluster) (pflex_cluster_compression_ratio{cluster=~\"$cluster\"})",
          "legendFormat": "Compression Ratio"
        }
      ]
    },
    {
      "id": 7,
      "type": "row",
      "title": "Capacity & Resilience",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Capacity (Used / Max)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "deckbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_capacity_in_use_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "expr": "sum by (cluster) (pflex_cluster_max_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Capacity At Risk (KiB)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "deckbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_degraded_failed_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "degraded+failed"
        },
        {
          "refId": "B",
          "expr": "sum by (cluster) (pflex_cluster_failed_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "failed"
        },
        {
          "refId": "C",
          "expr": "sum by (cluster) (pflex_cluster_degraded_healthy_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "degraded(healthy)"
        },
        {
          "refId": "D",
          "expr": "sum by (cluster) (pflex_cluster_spare_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "spare"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Rebuild / Rebalance Remaining (KiB)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "deckbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_bck_rebuild_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "bck rebuild"
        },
        {
          "refId": "B",
          "expr": "sum by (cluster) (pflex_cluster_fwd_rebuild_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "fwd rebuild"
        },
        {
          "refId": "C",
          "expr": "sum by (cluster) (pflex_cluster_rebalance_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "rebalance"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Snapshot Capacity (KiB)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "deckbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_snapshot_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "snapshot"
        },
        {
          "refId": "B",
          "expr": "sum by (cluster) (pflex_cluster_net_snapshot_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "net snapshot"
        },
        {
          "refId": "C",
          "expr": "sum by (cluster) (pflex_cluster_snap_capacity_in_use_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "in use"
        }
      ]
    },
    {
      "id": 12,
      "type": "row",
      "title": "Performance",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Total IOPS (read + write)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster, direction) (pflex_cluster_iops{cluster=~\"$cluster\", op=\"total\"})",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Total Bandwidth (KB/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "KBs",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster, direction) (pflex_cluster_bandwidth_kb_per_second{cluster=~\"$cluster\", op=\"total\"})",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "User IO Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (cluster, direction) (pflex_cluster_latency{cluster=~\"$cluster\", op=\"userDataSdc\"})",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Rebuild / Rebalance IOPS",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster, op) (pflex_cluster_iops{cluster=~\"$cluster\", op=~\"fwdRebuild|bckRebuild|normRebuild|rebalance\"})",
          "legendFormat": "{{op}}"
        }
      ]
    },
    {
      "id": 17,
      "type": "row",
      "title": "Inventory",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 41
      }
    },
    {
      "id": 18,
      "type": "stat",
      "title": "Volumes",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 42
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_num_of_volumes{cluster=~\"$cluster\"})",
          "legendFormat": "Volumes"
        }
      ]
    },
    {
      "id": 19,
      "type": "stat",
      "title": "SDS",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 42
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_num_of_sds{cluster=~\"$cluster\"})",
          "legendFormat": "SDS"
        }
      ]
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Devices",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 42
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_num_of_devices{cluster=~\"$cluster\"})",
          "legendFormat": "Devices"
        }
      ]
    }
  ],
  "description": "Cluster health, capacity & resilience, performance, and inventory at a glance. Detail lives in the per-object dashboards."
}
