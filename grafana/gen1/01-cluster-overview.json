{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "title": "PowerFlex - Cluster Overview",
  "uid": "pflex-cluster-overview",
  "tags": [
    "powerflex",
    "pflex_exporter"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "version": 3,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(pflex_up, cluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Health & Status",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Clusters Up",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pflex_up{cluster=~\"$cluster\"})",
          "legendFormat": "Clusters Up"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Capacity Used %",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (cluster) (pflex_cluster_capacity_in_use_in_kb{cluster=~\"$cluster\"}) / clamp_min(sum by (cluster) (pflex_cluster_max_capacity_in_kb{cluster=~\"$cluster\"}), 1)",
          "legendFormat": "Capacity Used %"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Capacity At Risk %",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (cluster) (pflex_cluster_degraded_failed_capacity_in_kb{cluster=~\"$cluster\"}) / clamp_min(sum by (cluster) (pflex_cluster_max_capacity_in_kb{cluster=~\"$cluster\"}), 1)",
          "legendFormat": "Capacity At Risk %"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Compression Ratio",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (cluster) (pflex_cluster_compression_ratio{cluster=~\"$cluster\"})",
          "legendFormat": "Compression Ratio"
        }
      ]
    },
    {
      "id": 6,
      "type": "state-timeline",
      "title": "Component Health Over Time",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Healthy",
                  "color": "green"
                },
                "1": {
                  "text": "Degraded",
                  "color": "yellow"
                },
                "2": {
                  "text": "Failed",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "rowHeight": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(pflex_sds_health{cluster=~\"$cluster\"})",
          "legendFormat": "SDS"
        },
        {
          "refId": "B",
          "expr": "max(pflex_device_health{cluster=~\"$cluster\"})",
          "legendFormat": "Device"
        },
        {
          "refId": "C",
          "expr": "max(pflex_sdc_health{cluster=~\"$cluster\"})",
          "legendFormat": "SDC"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Device Health & Wear",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true,
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "State"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "Healthy",
                        "color": "green"
                      },
                      "1": {
                        "text": "Degraded",
                        "color": "yellow"
                      },
                      "2": {
                        "text": "Failed",
                        "color": "red"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pflex_device_info{cluster=~\"$cluster\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "Value": true,
              "job": true,
              "instance": true,
              "cluster_id": true,
              "device_id": true,
              "storage_pool_id": true,
              "protection_domain_id": true,
              "sds_id": true
            },
            "renameByName": {
              "device_name": "Device",
              "sds": "SDS",
              "storage_pool_name": "Pool",
              "device_state": "State",
              "temperature_state": "Temp",
              "ssd_end_of_life_state": "SSD EOL",
              "error_state": "Error",
              "cluster": "Cluster"
            }
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "Capacity & Resilience",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 19
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Capacity (Used / Max)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "deckbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_capacity_in_use_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "expr": "sum by (cluster) (pflex_cluster_max_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Capacity At Risk (KiB)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "deckbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_degraded_failed_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "degraded+failed"
        },
        {
          "refId": "B",
          "expr": "sum by (cluster) (pflex_cluster_failed_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "failed"
        },
        {
          "refId": "C",
          "expr": "sum by (cluster) (pflex_cluster_degraded_healthy_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "degraded(healthy)"
        },
        {
          "refId": "D",
          "expr": "sum by (cluster) (pflex_cluster_spare_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "spare"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Rebuild / Rebalance Remaining (KiB)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "deckbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_bck_rebuild_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "bck rebuild"
        },
        {
          "refId": "B",
          "expr": "sum by (cluster) (pflex_cluster_fwd_rebuild_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "fwd rebuild"
        },
        {
          "refId": "C",
          "expr": "sum by (cluster) (pflex_cluster_rebalance_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "rebalance"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Snapshot Capacity (KiB)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "deckbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_snapshot_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "snapshot"
        },
        {
          "refId": "B",
          "expr": "sum by (cluster) (pflex_cluster_net_snapshot_capacity_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "net snapshot"
        },
        {
          "refId": "C",
          "expr": "sum by (cluster) (pflex_cluster_snap_capacity_in_use_in_kb{cluster=~\"$cluster\"})",
          "legendFormat": "in use"
        }
      ]
    },
    {
      "id": 13,
      "type": "row",
      "title": "Performance",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 36
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Total IOPS (read + write)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 37
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster, direction) (pflex_cluster_iops{cluster=~\"$cluster\", op=\"total\"})",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Total Bandwidth (KB/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 37
      },
      "fieldConfig": {
        "defaults": {
          "unit": "KBs",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster, direction) (pflex_cluster_bandwidth_kb_per_second{cluster=~\"$cluster\", op=\"total\"})",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "User IO Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 37
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (cluster, direction) (pflex_cluster_latency{cluster=~\"$cluster\", op=\"userDataSdc\"})",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Rebuild / Rebalance IOPS",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 45
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster, op) (pflex_cluster_iops{cluster=~\"$cluster\", op=~\"fwdRebuild|bckRebuild|normRebuild|rebalance\"})",
          "legendFormat": "{{op}}"
        }
      ]
    },
    {
      "id": 18,
      "type": "row",
      "title": "Inventory",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 53
      }
    },
    {
      "id": 19,
      "type": "stat",
      "title": "Volumes",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 54
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_num_of_volumes{cluster=~\"$cluster\"})",
          "legendFormat": "Volumes"
        }
      ]
    },
    {
      "id": 20,
      "type": "stat",
      "title": "SDS",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 54
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_num_of_sds{cluster=~\"$cluster\"})",
          "legendFormat": "SDS"
        }
      ]
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Devices",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 54
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_num_of_devices{cluster=~\"$cluster\"})",
          "legendFormat": "Devices"
        }
      ]
    }
  ],
  "description": "Cluster health, capacity & resilience, performance, and inventory at a glance. Detail lives in the per-object dashboards."
}
