{
  "title": "PowerFlex Gen2 - Cluster Capacity",
  "uid": "pflex-g2-capacity",
  "tags": [
    "powerflex",
    "pflex_exporter"
  ],
  "schemaVersion": 39,
  "version": 2,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(pflex_up, cluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Capacity",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Capacity Used %",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (cluster) (pflex_cluster_physical_used{cluster=~\"$cluster\"}) / clamp_min(sum by (cluster) (pflex_cluster_physical_total{cluster=~\"$cluster\"}), 1)",
          "legendFormat": "Capacity Used %"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Physical (Used / Total / Free)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_physical_used{cluster=~\"$cluster\"})",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "expr": "sum by (cluster) (pflex_cluster_physical_total{cluster=~\"$cluster\"})",
          "legendFormat": "total"
        },
        {
          "refId": "C",
          "expr": "sum by (cluster) (pflex_cluster_physical_free{cluster=~\"$cluster\"})",
          "legendFormat": "free"
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "Efficiency",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Logical (Used / Provisioned)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (pflex_cluster_logical_used{cluster=~\"$cluster\"})",
          "legendFormat": "logical used"
        },
        {
          "refId": "B",
          "expr": "sum by (cluster) (pflex_cluster_logical_provisioned{cluster=~\"$cluster\"})",
          "legendFormat": "logical provisioned"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Reduction & Efficiency Ratios",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (cluster) (pflex_cluster_data_reduction_ratio{cluster=~\"$cluster\"})",
          "legendFormat": "data reduction"
        },
        {
          "refId": "B",
          "expr": "max by (cluster) (pflex_cluster_efficiency_ratio{cluster=~\"$cluster\"})",
          "legendFormat": "efficiency"
        }
      ]
    }
  ],
  "description": "Gen2 cluster physical capacity and efficiency."
}
