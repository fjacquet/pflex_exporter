{
  "title": "PowerFlex Gen2 - Pools",
  "uid": "pflex-g2-pools",
  "tags": ["powerflex", "gen2", "pflex_exporter"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0 },
      { "name": "cluster", "type": "query", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "query": "label_values(pflex_cluster_generation{generation=\"gen2\"}, cluster)", "refresh": 2, "includeAll": true, "multi": true, "current": { "text": "All", "value": "$__all" } },
      { "name": "pool", "type": "query", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "query": "label_values(pflex_storagepool_physical_total{cluster=~\"$cluster\"}, storage_pool_name)", "refresh": 2, "includeAll": true, "multi": true, "current": { "text": "All", "value": "$__all" } }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Pool Capacity Used % (physical)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "100 * pflex_storagepool_physical_used{cluster=~\"$cluster\", storage_pool_name=~\"$pool\"} / pflex_storagepool_physical_total{cluster=~\"$cluster\", storage_pool_name=~\"$pool\"}", "legendFormat": "{{storage_pool_name}}" } ]
    },
    {
      "id": 2, "title": "Pool Host IOPS", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "iops" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (storage_pool_name, direction) (pflex_storagepool_iops{cluster=~\"$cluster\", storage_pool_name=~\"$pool\", op=\"host\"})", "legendFormat": "{{storage_pool_name}} {{direction}}" } ]
    },
    {
      "id": 3, "title": "Pool Bandwidth (bytes/s)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (storage_pool_name, direction) (pflex_storagepool_bandwidth_bytes_per_second{cluster=~\"$cluster\", storage_pool_name=~\"$pool\", op=\"host\"})", "legendFormat": "{{storage_pool_name}} {{direction}}" } ]
    },
    {
      "id": 4, "title": "Pool Data Reduction Ratio", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 2 }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "max by (storage_pool_name) (pflex_storagepool_data_reduction_ratio{cluster=~\"$cluster\", storage_pool_name=~\"$pool\"})", "legendFormat": "{{storage_pool_name}}" } ]
    }
  ]
}
