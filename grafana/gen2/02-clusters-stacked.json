{
  "title": "PowerFlex Gen2 - Clusters (Stacked)",
  "uid": "pflex-g2-clusters-stacked",
  "tags": ["powerflex", "gen2", "pflex_exporter"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0 }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Host IOPS by Cluster", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "iops", "custom": { "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (cluster) (pflex_cluster_iops{op=\"host\"})", "legendFormat": "{{cluster}}" } ]
    },
    {
      "id": 2, "title": "Host Bandwidth by Cluster (bytes/s)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (cluster) (pflex_cluster_bandwidth_bytes_per_second{op=\"host\"})", "legendFormat": "{{cluster}}" } ]
    },
    {
      "id": 3, "title": "Physical Used by Cluster", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (cluster) (pflex_cluster_physical_used)", "legendFormat": "{{cluster}}" } ]
    }
  ]
}
