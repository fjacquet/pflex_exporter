{
  "title": "PowerFlex Gen2 - SDC / Hosts",
  "uid": "pflex-g2-sdc",
  "tags": ["powerflex", "gen2", "pflex_exporter"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0 },
      { "name": "cluster", "type": "query", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "query": "label_values(pflex_cluster_generation{generation=\"gen2\"}, cluster)", "refresh": 2, "includeAll": true, "multi": true, "current": { "text": "All", "value": "$__all" } }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "SDC IOPS", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "iops" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "topk(15, sum by (sdc_name, direction) (pflex_sdc_iops{cluster=~\"$cluster\", op=\"host\"}))", "legendFormat": "{{sdc_name}} {{direction}}" } ]
    },
    {
      "id": 2, "title": "SDC Bandwidth (bytes/s)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "topk(15, sum by (sdc_name, direction) (pflex_sdc_bandwidth_bytes_per_second{cluster=~\"$cluster\", op=\"host\"}))", "legendFormat": "{{sdc_name}} {{direction}}" } ]
    },
    {
      "id": 3, "title": "SDC Latency (µs)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "µs" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "avg by (sdc_name, direction) (pflex_sdc_latency_microseconds{cluster=~\"$cluster\", op=\"host\"})", "legendFormat": "{{sdc_name}} {{direction}}" } ]
    }
  ]
}
