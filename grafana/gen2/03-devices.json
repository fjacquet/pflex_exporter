{
  "title": "PowerFlex Gen2 - Devices",
  "uid": "pflex-g2-devices",
  "tags": [
    "powerflex",
    "pflex_exporter"
  ],
  "schemaVersion": 39,
  "version": 2,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(pflex_up, cluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Health",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Worst Health",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Healthy",
                  "color": "green"
                },
                "1": {
                  "text": "Degraded",
                  "color": "yellow"
                },
                "2": {
                  "text": "Failed",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(pflex_device_health{cluster=~\"$cluster\"})",
          "legendFormat": "Worst Health"
        }
      ]
    },
    {
      "id": 3,
      "type": "state-timeline",
      "title": "Health Over Time",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 18,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Healthy",
                  "color": "green"
                },
                "1": {
                  "text": "Degraded",
                  "color": "yellow"
                },
                "2": {
                  "text": "Failed",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "rowHeight": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (device_name) (pflex_device_health{cluster=~\"$cluster\"})",
          "legendFormat": "{{device_name}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Detail",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true,
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "State"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "Healthy",
                        "color": "green"
                      },
                      "1": {
                        "text": "Degraded",
                        "color": "yellow"
                      },
                      "2": {
                        "text": "Failed",
                        "color": "red"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pflex_device_info{cluster=~\"$cluster\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "Value": true,
              "job": true,
              "instance": true,
              "cluster_id": true,
              "device_id": true
            },
            "renameByName": {
              "device_name": "Name",
              "cluster": "Cluster",
              "device_state": "State",
              "mdm_connection_state": "MDM Conn",
              "temperature_state": "Temp",
              "ssd_end_of_life_state": "SSD EOL",
              "error_state": "Error"
            }
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Performance",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "IOPS",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (device_name) (pflex_device_iops{cluster=~\"$cluster\", op=\"total\"})",
          "legendFormat": "{{device_name}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Bandwidth",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (device_name) (pflex_device_bandwidth_bytes_per_second{cluster=~\"$cluster\", op=\"total\"})",
          "legendFormat": "{{device_name}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "\u00b5s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (device_name) (pflex_device_latency_microseconds{cluster=~\"$cluster\", op=\"device\"})",
          "legendFormat": "{{device_name}}"
        }
      ]
    }
  ],
  "description": "Device health/wear and performance (Gen2)."
}
